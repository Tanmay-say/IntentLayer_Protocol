{
  "name": "@intentlayer/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IntentLayer MCP server — full control surface for LLM clients (Phase E)",
  "bin": {
    "intentlayer-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@intentlayer/intent-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.7",
    "pino": "^9.5.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
