# ==============================================================
# IntentLayer-specific
# ==============================================================

# ---- Secrets & environment ----
# NEVER commit real .env — contains private keys, API tokens, RPC URLs
.env
.env.local
.env.*.local
intentlayer/.env
intentlayer/.env.local

# ---- AXL daemon ----
# Compiled Go binary (built by install-axl.sh) and per-daemon data dirs
axl
intentlayer/scripts/axl
axl-a-datadir/
axl-b-datadir/
axl-observer-datadir/
*.axl.pid

# ---- Foundry / Solidity build artifacts ----
intentlayer/packages/contracts/out/
intentlayer/packages/contracts/cache/
intentlayer/packages/contracts/broadcast/
**/.cache/foundry/

# ---- Generated deployment manifests ----
# Written by pnpm deploy:fresh — contain live contract addresses
intentlayer/packages/contracts/deployments.json
intentlayer/packages/contracts/deployments*.json

# ---- Agent B stealth runtime state ----
# Persisted JSON may contain ephemeral key material and seen-set
intentlayer-agent-b-state.json

# ---- Admin API local stores ----
intentlayer/apps/admin-api/*.db
intentlayer/apps/admin-api/*.sqlite
intentlayer/apps/admin-api/events*.json

# ---- TypeScript dist output ----
intentlayer/packages/*/dist/
intentlayer/apps/*/dist/
intentlayer/apps/admin-web/dist/

# ---- Graphify knowledge graph (auto-generated, not source) ----
graphify-out/

# ---- Misc generated / tool files ----
*.skill
.skill/
.emergent/